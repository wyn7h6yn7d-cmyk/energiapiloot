# =============================================================================
# Energiapiloot — environment template
# Copy to `.env.local` for development. On Vercel, set variables in
# Project Settings → Environment Variables.
# =============================================================================

# --- Site / Next.js (production) ---------------------------------------------
# Canonical origin: no trailing slash. Required for sitemap, OG URLs, and metadataBase.
# Vercel: set per environment (Production = https://your-domain.com, Preview = deployment URL optional).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (required for API routes & server actions that use the client) ---
# Project Settings → API: Project URL + anon (public) key.
# Never commit service role keys to client bundles; use server-only env if you add admin operations.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: server-only, for future webhooks / admin scripts (not used by current app code).
# SUPABASE_SERVICE_ROLE_KEY=

# Supabase Auth: add your production and preview URLs under Authentication → URL Configuration:
# - Site URL: https://your-domain.com
# - Redirect URLs: https://your-domain.com/** , https://*.vercel.app/**

# --- Stripe (unlock / checkout — optional until checkout is live) ------------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_PRICE_UNLOCK_PREMIUM_RESULTS=
# STRIPE_PRICE_UNLOCK_REPORT=
# STRIPE_PRICE_UNLOCK_DOWNLOAD=
# STRIPE_PRICE_UNLOCK_BUNDLE=

# --- Integrations (server-only) ----------------------------------------------
# mock: safe demo data | live: real HTTP only | hybrid: try live, fall back to mock on failures
ENERGIAPILOOT_API_MODE=mock

# Elering Estfeed / Datahub (live: OAuth/client credentials not implemented yet)
ELERING_ESTFEED_BASE_URL=
ELERING_ESTFEED_TOKEN_URL=
ELERING_ESTFEED_CLIENT_ID=
ELERING_ESTFEED_CLIENT_SECRET=

# Nord Pool Data Portal (live URL + response parser must match your subscription)
NORD_POOL_BASE_URL=https://dataportal-api.nordpoolgroup.com
NORD_POOL_API_KEY=
NORD_POOL_DEFAULT_AREA=EE

# PVGIS v5.2 (public; keep server-side in adapters)
PVGIS_BASE_URL=https://re.jrc.ec.europa.eu/api/v5_2

# Open-Meteo
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# Address / geocoding (Maa-amet / In-ADS — implement parser in adapter)
ADDRESS_API_PROVIDER=mock
ADDRESS_API_BASE_URL=
ADDRESS_API_KEY=

# Business registry (RIK — implement parser in adapter)
BUSINESS_REGISTRY_PROVIDER=mock
BUSINESS_REGISTRY_BASE_URL=
BUSINESS_REGISTRY_API_KEY=

# Cache TTLs (seconds, in-process; swap MemoryCache for Redis later)
CACHE_MARKET_TTL_SEC=300
CACHE_WEATHER_TTL_SEC=900
CACHE_ADDRESS_TTL_SEC=3600
CACHE_PVGIS_TTL_SEC=86400
CACHE_COMPANY_TTL_SEC=21600
CACHE_ESTFEED_SERIES_TTL_SEC=600

# HTTP client
HTTP_TIMEOUT_MS=20000
HTTP_MAX_RETRIES=2
